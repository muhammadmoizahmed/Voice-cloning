# VoiceForge AI - API Configuration
# No local model training required - uses external APIs only

# App Settings
DEBUG=false
APP_NAME=VoiceForge AI
APP_VERSION=1.0.0

# Paths
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# ElevenLabs API - Voice Cloning (Primary)
# Get API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=  # Optional: Default voice ID to use

# Alternative Voice APIs:
# Play.ht API - https://play.ht/
PLAYHT_API_KEY=
PLAYHT_USER_ID=

# =============================================================================
# LIP SYNC APIs (Choose one)
# =============================================================================

# Sync.so API - Lip Sync (Recommended)
# Get API key from: https://sync.so/
SYNCSO_API_KEY=your_syncso_api_key_here

# D-ID API - Talking Head (Alternative)
# Get API key from: https://studio.d-id.com/
DID_API_KEY=your_did_api_key_here

# HeyGen API - Talking Head (Alternative)
# Get API key from: https://app.heygen.com/settings/api-keys
HEYGEN_API_KEY=your_heygen_api_key_here

# =============================================================================
# Video Settings
# =============================================================================
FPS=25
