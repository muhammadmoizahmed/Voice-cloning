# Backend Environment Variables
DEBUG=false
APP_NAME=VoiceForge AI
APP_VERSION=1.0.0

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///./voiceforge.db
# DATABASE_URL=postgresql://user:password@localhost/voiceforge

# JWT Secret (Change in production!)
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# File Paths
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_UPLOAD_SIZE=10485760

# External APIs
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key_here

# Stripe (Optional - for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# Plan Limits (minutes per month)
FREE_PLAN_MINUTES=10
PRO_PLAN_MINUTES=120
BUSINESS_PLAN_MINUTES=500

# Security
WATERMARK_ENABLED=true
REQUIRE_VOICE_OWNERSHIP=true
